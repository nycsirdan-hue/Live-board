const defaultConfig = {
  eventName: "Tonight's Board",
  venueName: "The Kink Collective",
  requireNickname: true,
  minSelectedItems: 1,
  maxSelectedItems: 12,
};

const catalogSet = new Set(Object.values(kinkCatalog).flat());
const allCatalogItems = Array.from(catalogSet).sort((a, b) => a.localeCompare(b));

const sectionThemes = {
  Top: {
    section: "border-rose-900/80 bg-rose-950/40",
    card: "border-rose-900/70 bg-rose-950/35",
    title: "text-rose-100",
  },
  Bottom: {
    section: "border-emerald-900/80 bg-emerald-950/35",
